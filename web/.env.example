# Copy to .env and fill in. Used by `npm run voice` (scripts/generate-voice.mjs).

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# The character voices (thick Russian-accented English voices from the
# ElevenLabs Voice Library). Discover ids with:  npm run voice -- --find russian
ELEVEN_VOICE_COOK=     # male tutor
ELEVEN_VOICE_MOM=      # female "Mom"

# Mom's Room counter cast (banter after each story problem). See SPEAKERS in
# src/voiceLines.js for the voice direction (desc) for each.
ELEVEN_VOICE_KID=      # bright child apprentice
ELEVEN_VOICE_GRANDPA=  # gruff old grandpa
# The Cat does NOT use a voice — it only meows. Those clips are generated as
# sound effects from MEOW_SFX in src/voiceLines.js (no id needed).
