{
  "name": "fractions-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web client for the fraction-adding tutoring game. Opens on the lesson map (Babushka's Fractions).",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "voice": "node scripts/generate-voice.mjs",
    "audition": "node scripts/audition-voices.mjs",
    "music-audition": "node scripts/fetch-music-audition.mjs",
    "music-fetch": "node scripts/fetch-music.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
